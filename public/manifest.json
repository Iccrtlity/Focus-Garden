{
  "manifest_version": 3,
  "name": "Focus Garden",
  "version": "1.1",
  "description": "A Pomodoro timer that grows a virtual garden as you focus. Stay productive and watch your garden flourish, one session at a time.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage"]
}
